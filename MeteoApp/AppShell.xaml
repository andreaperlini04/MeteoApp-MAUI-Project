<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="MeteoApp.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:MeteoApp"
    xmlns:res="clr-namespace:MeteoApp.Resources.Strings;assembly=MeteoApp"
    Title="{x:Static res:AppResources.AppShell_Title}">

    <TabBar>
        <Tab Title="{x:Static res:AppResources.AppShell_HomeTab}">
            <ShellContent ContentTemplate="{DataTemplate local:MeteoListPage}" />
        </Tab>
    </TabBar>
</Shell>
