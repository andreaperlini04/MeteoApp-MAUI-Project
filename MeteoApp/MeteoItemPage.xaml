<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MeteoApp.MeteoItemPage"
             Title="Dettagli Meteo">
    
    <StackLayout x:Name="MainLayout" Spacing="20" VerticalOptions="Center" HorizontalOptions="Center">
        
        <Label Text="{Binding Entry.CityName}"
               FontSize="40"
               FontAttributes="Bold"
               HorizontalOptions="Center" />
               
        <Label Text="{Binding TemperatureText}"
               FontSize="55"
               TextColor="DodgerBlue"
               HorizontalOptions="Center" />
               
    </StackLayout>
</ContentPage>