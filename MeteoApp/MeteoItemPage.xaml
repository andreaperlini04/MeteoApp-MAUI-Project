<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MeteoApp.MeteoItemPage"
             Title="Dettagli Meteo">
    
    <VerticalStackLayout x:Name="MainLayout" Spacing="30" Padding="20">
        
        <Label Text="{Binding Entry.Name}"
               FontSize="45"
               HorizontalOptions="Center" 
               VerticalOptions="Start" />
               
        <Label Text="{Binding TemperatureText}"
               FontSize="35"
               TextColor="{StaticResource Primary}"
               HorizontalOptions="Center" />

        <HorizontalStackLayout HorizontalOptions="Center" Spacing="40">
            
            <Label Text="{Binding TemperatureMinText, StringFormat='Min: {0}'}"
                   FontSize="22"
                   TextColor="LightGray" />

            <Label Text="{Binding TemperatureMaxText, StringFormat='Max: {0}'}"
                   FontSize="22"
                   TextColor="LightGray" />
                   
        </HorizontalStackLayout>
        
    </VerticalStackLayout>
</ContentPage>