<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:maps="clr-namespace:Microsoft.Maui.Controls.Maps;assembly=Microsoft.Maui.Controls.Maps"
             xmlns:res="clr-namespace:MeteoApp.Resources.Strings;assembly=MeteoApp"
             x:Class="MeteoApp.AddLocationPage"
             Title="{x:Static res:AppResources.AddLocation_Title}">

    <ContentPage.ToolbarItems>
        <ToolbarItem Text="{x:Static res:AppResources.AddLocation_Cancel}" Clicked="OnCancel" />
        <ToolbarItem Text="{x:Static res:AppResources.AddLocation_Save}"   Clicked="OnSave" />
    </ContentPage.ToolbarItems>

    <Grid RowDefinitions="Auto, *">

        <Entry Grid.Row="0"
               x:Name="CityEntry"
               Placeholder="{x:Static res:AppResources.AddLocation_Placeholder}"
               TextChanged="OnCityEntryTextChanged"
               Margin="15,10" />

        <maps:Map Grid.Row="1"
                  x:Name="MyMap"
                  MapClicked="OnMapClicked"
                  IsShowingUser="false"
                  MapType="Street" />

    </Grid>

</ContentPage>
