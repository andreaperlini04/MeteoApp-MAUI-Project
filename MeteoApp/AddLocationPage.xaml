<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:maps="clr-namespace:Microsoft.Maui.Controls.Maps;assembly=Microsoft.Maui.Controls.Maps"
             x:Class="MeteoApp.AddLocationPage"
             Title="Aggiungi Posizione">

    <ContentPage.ToolbarItems>
        <ToolbarItem Text="Annulla" Clicked="OnCancel" />
        <ToolbarItem Text="Salva" Clicked="OnSave" />
    </ContentPage.ToolbarItems>

    <Grid RowDefinitions="Auto, *">

        <Entry Grid.Row="0"
               x:Name="CityEntry"
               Placeholder="Clicca sulla mappa o scrivi il nome"
               TextChanged="OnCityEntryTextChanged"
               Margin="15,10" />

        <maps:Map Grid.Row="1"
                  x:Name="MyMap"
                  MapClicked="OnMapClicked"
                  IsShowingUser="false"
                  MapType="Street" />

    </Grid>

</ContentPage>
